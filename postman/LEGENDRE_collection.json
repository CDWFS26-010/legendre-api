{
  "info": {
    "name": "API LEGENDRE - Logistique",
    "description": "⚠️ Commencer par lancer les 3 requêtes du dossier Auth dans l'ordre pour initialiser les tokens.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3000" },
    { "key": "token_admin", "value": "" },
    { "key": "token_chauffeur", "value": "" },
    { "key": "token_client", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Admin",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('token_admin', pm.response.json().token);",
            "  pm.test('Token admin stocké ✅', () => pm.expect(pm.response.json()).to.have.property('token'));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\": \"admin@legendre.fr\", \"password\": \"Test1234!\"}" }
          }
        },
        {
          "name": "Login Chauffeur",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('token_chauffeur', pm.response.json().token);",
            "  pm.test('Token chauffeur stocké ✅', () => pm.expect(pm.response.json()).to.have.property('token'));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\": \"p.martin@legendre.fr\", \"password\": \"Test1234!\"}" }
          }
        },
        {
          "name": "Login Client",
          "event": [{ "listen": "test", "script": { "exec": [
            "if (pm.response.code === 200) {",
            "  pm.collectionVariables.set('token_client', pm.response.json().token);",
            "  pm.test('Token client stocké ✅', () => pm.expect(pm.response.json()).to.have.property('token'));",
            "}"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\": \"m.dupont@email.fr\", \"password\": \"Test1234!\"}" }
          }
        },
        {
          "name": "Login mauvais mot de passe → 401",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Retourne 401 ✅', () => pm.expect(pm.response.code).to.equal(401));"
          ]}}],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": { "mode": "raw", "raw": "{\"email\": \"admin@legendre.fr\", \"password\": \"mauvais\"}" }
          }
        }
      ]
    },
    {
      "name": "Chauffeurs",
      "item": [
        {
          "name": "GET /chauffeurs (admin → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": "{{base_url}}/chauffeurs"
          }
        },
        {
          "name": "GET /chauffeurs (chauffeur → 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 🔒', () => pm.expect(pm.response.code).to.equal(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_chauffeur}}" }],
            "url": "{{base_url}}/chauffeurs"
          }
        },
        {
          "name": "GET /chauffeurs/:id ses propres infos (chauffeur → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_chauffeur}}" }],
            "url": "{{base_url}}/chauffeurs/00000000-0000-0000-0000-000000000002"
          }
        },
        {
          "name": "GET /chauffeurs/:id autre chauffeur (chauffeur → 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 🔒', () => pm.expect(pm.response.code).to.equal(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_chauffeur}}" }],
            "url": "{{base_url}}/chauffeurs/00000000-0000-0000-0000-000000000003"
          }
        },
        {
          "name": "GET /chauffeurs/:id/tournees (chauffeur → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_chauffeur}}" }],
            "url": "{{base_url}}/chauffeurs/00000000-0000-0000-0000-000000000002/tournees"
          }
        }
      ]
    },
    {
      "name": "Tournées",
      "item": [
        {
          "name": "GET /tournees (admin → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": "{{base_url}}/tournees"
          }
        },
        {
          "name": "GET /tournees/:id/livraisons avec marchandises (admin → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));",
            "pm.test('Contient marchandises', () => {",
            "  const body = pm.response.json();",
            "  if (body.length > 0) pm.expect(body[0]).to.have.property('marchandises');",
            "});"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": "{{base_url}}/tournees/00000000-0000-0000-0000-000000000030/livraisons"
          }
        },
        {
          "name": "GET /tournees/:id autre chauffeur (chauffeur → 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 🔒', () => pm.expect(pm.response.code).to.equal(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_chauffeur}}" }],
            "url": "{{base_url}}/tournees/00000000-0000-0000-0000-000000000031"
          }
        }
      ]
    },
    {
      "name": "Livraisons",
      "item": [
        {
          "name": "PATCH statut → en_cours (chauffeur → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));",
            "pm.test('Statut = en_cours', () => pm.expect(pm.response.json().statut).to.equal('en_cours'));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_chauffeur}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/livraisons/00000000-0000-0000-0000-000000000040/statut",
            "body": { "mode": "raw", "raw": "{\"statut\": \"en_cours\"}" }
          }
        },
        {
          "name": "PATCH statut → livree (chauffeur → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));",
            "pm.test('Statut = livree', () => pm.expect(pm.response.json().statut).to.equal('livree'));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_chauffeur}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/livraisons/00000000-0000-0000-0000-000000000040/statut",
            "body": { "mode": "raw", "raw": "{\"statut\": \"livree\"}" }
          }
        },
        {
          "name": "PATCH statut (client → 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 🔒', () => pm.expect(pm.response.code).to.equal(403));"
          ]}}],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token_client}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/livraisons/00000000-0000-0000-0000-000000000040/statut",
            "body": { "mode": "raw", "raw": "{\"statut\": \"livree\"}" }
          }
        },
        {
          "name": "GET /livraisons/:id sa propre livraison (client → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_client}}" }],
            "url": "{{base_url}}/livraisons/00000000-0000-0000-0000-000000000040"
          }
        },
        {
          "name": "GET /livraisons/:id livraison d'un autre (client → 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 🔒', () => pm.expect(pm.response.code).to.equal(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_client}}" }],
            "url": "{{base_url}}/livraisons/00000000-0000-0000-0000-000000000041"
          }
        }
      ]
    },
    {
      "name": "Clients",
      "item": [
        {
          "name": "GET /clients (admin → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": "{{base_url}}/clients"
          }
        },
        {
          "name": "GET /clients/:id ses propres infos (client → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_client}}" }],
            "url": "{{base_url}}/clients/00000000-0000-0000-0000-000000000004"
          }
        },
        {
          "name": "GET /clients/:id infos d'un autre (client → 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 🔒', () => pm.expect(pm.response.code).to.equal(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_client}}" }],
            "url": "{{base_url}}/clients/00000000-0000-0000-0000-000000000005"
          }
        },
        {
          "name": "GET /clients/:id/livraisons (client → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_client}}" }],
            "url": "{{base_url}}/clients/00000000-0000-0000-0000-000000000004/livraisons"
          }
        }
      ]
    },
    {
      "name": "Marchandises",
      "item": [
        {
          "name": "GET /marchandises (admin → 200)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('200 ✅', () => pm.expect(pm.response.code).to.equal(200));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_admin}}" }],
            "url": "{{base_url}}/marchandises"
          }
        },
        {
          "name": "GET /marchandises (client → 403)",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('403 🔒', () => pm.expect(pm.response.code).to.equal(403));"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token_client}}" }],
            "url": "{{base_url}}/marchandises"
          }
        }
      ]
    }
  ]
}
